dist: distdir FORCE
	(cd `dirname $(DISTDIR)` && $(TAR) $(DISTNAME).tar $(DISTNAME) && $(COMPRESS) $(DISTNAME).tar) && $(MOVE) `dirname $(DISTDIR)`/$(DISTNAME).tar.gz . && $(DEL_FILE) -r $(DISTDIR)

distdir: FORCE
	@test -d $(DISTDIR) || mkdir -p $(DISTDIR)
	$(COPY_FILE) --parents $(DIST) $(DISTDIR)/
	$(COPY_FILE) --parents res/resfile.qrc $(DISTDIR)/
	$(COPY_FILE) --parents /usr/lib/x86_64-linux-gnu/qt5/mkspecs/features/data/dummy.cpp $(DISTDIR)/
	$(COPY_FILE) --parents ../libukmge/interface/interface.h ../libukmge/widgets/FlowLayout/flowlayout.h ../backend/xdgpaths.h ../backend/desktopfilehandler.h ../backend/menuparser.h ../backend/menuwriter.h mainwindow.h titlewidget.h leftsidebarwidget.h mstackwidget.h menutreewidget.h applicationeditorwidget.h editorwidget.h searchbar.h $(DISTDIR)/
	$(COPY_FILE) --parents ../libukmge/widgets/FlowLayout/flowlayout.cpp ../backend/xdgpaths.cpp ../backend/desktopfilehandler.cpp ../backend/menuparser.cpp ../backend/menuwriter.cpp main.cpp mainwindow.cpp titlewidget.cpp leftsidebarwidget.cpp mstackwidget.cpp menutreewidget.cpp applicationeditorwidget.cpp editorwidget.cpp searchbar.cpp $(DISTDIR)/
	$(COPY_FILE) --parents res/i18n/en_US.ts res/i18n/pt_BR.ts $(DISTDIR)/


