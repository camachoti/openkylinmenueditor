####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/usr/bin || mkdir -p $(INSTALL_ROOT)/usr/bin
	$(QINSTALL_PROGRAM) ../bin/$(QMAKE_TARGET) $(INSTALL_ROOT)/usr/bin/$(QMAKE_TARGET)
	-$(STRIP) $(INSTALL_ROOT)/usr/bin/$(QMAKE_TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) $(INSTALL_ROOT)/usr/bin/$(QMAKE_TARGET)
	-$(DEL_DIR) $(INSTALL_ROOT)/usr/bin/ 


install_desktop: first FORCE
	@test -d $(INSTALL_ROOT)/usr/share/applications || mkdir -p $(INSTALL_ROOT)/usr/share/applications
	$(QINSTALL) /home/camacho/git/openkylinmenueditor/shell/openkylinmenueditor.desktop $(INSTALL_ROOT)/usr/share/applications/openkylinmenueditor.desktop

uninstall_desktop: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/share/applications/openkylinmenueditor.desktop
	-$(DEL_DIR) $(INSTALL_ROOT)/usr/share/applications/ 


install_modules: first FORCE
	@test -d $(INSTALL_ROOT)/usr/share/openkylinmenueditor/data/ || mkdir -p $(INSTALL_ROOT)/usr/share/openkylinmenueditor/data/
	$(QINSTALL) /home/camacho/git/openkylinmenueditor/data/openkylinmenueditor-config.json $(INSTALL_ROOT)/usr/share/openkylinmenueditor/data/openkylinmenueditor-config.json

uninstall_modules: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/share/openkylinmenueditor/data/openkylinmenueditor-config.json
	-$(DEL_DIR) $(INSTALL_ROOT)/usr/share/openkylinmenueditor/data/ 


install: install_target install_desktop install_modules  FORCE

uninstall: uninstall_target uninstall_desktop uninstall_modules  FORCE

FORCE:

